# ─────────────────────────────────────────────────────────────
# MTC CASILLA BOT — Variables de entorno
# Copiá este archivo a .env y completá los valores reales.
# .env NUNCA debe commitearse (ya está en .gitignore).
# ─────────────────────────────────────────────────────────────

# ─── APIs de IA (locales en Python) ──────────────────────────
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
GEMINI_MODEL=gemini-2.5-flash

# ─── Google Cloud (service account) ──────────────────────────
GOOGLE_SERVICE_ACCOUNT_JSON=data/credentials/service-account.json

# ID de la carpeta raíz en Drive (de la URL: drive.google.com/drive/folders/<ID>)
DRIVE_ROOT_FOLDER_ID=1aBcDeFgHiJkLmNoPqRsTuVwXyZ

# Subcarpeta de plantillas dentro de la carpeta raíz (Fase 2)
DRIVE_TEMPLATES_FOLDER=_templates

# ─── Google Sheets ───────────────────────────────────────────
# ID del Sheet "MTC Casilla DB" (de la URL: spreadsheets/d/<ID>/edit)
SHEET_ID=1xYzAbCdEfGhIjKlMnOpQrStUvWxYz

SHEET_TAB_NOTIFICACIONES=notificaciones
SHEET_TAB_LOGS=logs
SHEET_TAB_RUCS=rucs

# ─── Apps Script API ─────────────────────────────────────────
# URL del Web App (después de deployar). El bot Python NO la necesita
# para escribir, pero la usa para healthcheck.
APPSCRIPT_API_URL=https://script.google.com/macros/s/REEMPLAZAR/exec

# Token compartido para POSTs autenticados (Fase 3)
APPSCRIPT_TOKEN=cambiar-este-token-largo-aleatorio-de-32-caracteres

# ─── Bóveda Obsidian (opcional) ──────────────────────────────
OBSIDIAN_VAULT_PATH=C:\Users\User\Documents\CEREBRO DIGITAL\RESOLVE\RESOLVE
OBSIDIAN_TEMPLATES_FOLDER=_templates
OBSIDIAN_NOTES_SUBFOLDER=

# Si querés desactivar la escritura a Obsidian (solo Drive/Sheet):
ENABLE_OBSIDIAN_WRITER=true

# ─── Credenciales MTC ────────────────────────────────────────
MTC_CREDENTIALS_CSV=data/credentials/rucs.csv

# ─── Configuración del scraper ───────────────────────────────
MTC_BOT_HEADED=0
PLAYWRIGHT_TIMEOUT=30000
MAX_CONCURRENT_RUCS=1
MAX_RETRIES=3

# ─── Sistema de plantillas (Fase 2) ──────────────────────────
TEMPLATE_MATCH_MIN_SCORE=30
TEMPLATE_MATCH_HIGH_SCORE=100

# ─── IA: parámetros ──────────────────────────────────────────
AI_TEMPERATURE=0.1
AI_MAX_TOKENS=1024
AI_TIMEOUT_SECONDS=60

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/mtc_bot.log
